MYSQL_DATABASE=devops_platform
MYSQL_USER=devops
MYSQL_PASSWORD=your_password_here
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# 生产环境建议显式配置
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-random-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 测试数据库（仅在 DJANGO_TEST_USE_SQLITE=false 时使用）
MYSQL_TEST_DATABASE=test_devops_platform

# 测试时是否强制使用 SQLite（默认 true，避免 MySQL 创建测试库权限问题）
DJANGO_TEST_USE_SQLITE=true
